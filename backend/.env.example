SERVICE_NAME=qeet-identity
SERVICE_ENV=dev
HTTP_PORT=4001
LOG_LEVEL=info

DB_URL=postgres://postgres:password@localhost:5001/qeet_identity?sslmode=disable
DB_MIN_CONNS=2
DB_MAX_CONNS=10

# 32-byte random hex; used for signing access & refresh tokens in dev.
# In prod, swap to RS256 with JWKS.
JWT_SECRET=please-change-me-please-change-me
JWT_ISSUER=qeet-identity
JWT_AUDIENCE=qeet-identity
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

# Frontend dev ports: 3001=qeetid-web, 3002=qeetid-admin, 3003=qeetid-docs.
# Plus 3000/5173 for general Next.js/Vite defaults.
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3000,http://localhost:5173

# Dev-only: trust X-Dev-User / X-Dev-Tenant headers (Postman shortcut).
AUTH_DEV_TRUST_HEADERS=true

# Dev-only: skip the CSRF middleware so Postman/curl can hit public mutation
# routes (signup/login/recovery/invites-accept) without Origin + double-submit
# cookie plumbing. main.go refuses to start with this set outside SERVICE_ENV=dev.
CSRF_DISABLED=false
